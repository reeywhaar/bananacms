#!/bin/bash
set -euo pipefail

mkdir -p private
rm -f private/bananacms.tgz

npm run build

filename=$(npm pack --pack-destination private --ignore-scripts --json \
  | node -e "process.stdout.write(JSON.parse(require('fs').readFileSync(0,'utf8'))[0].filename)")

mv "private/$filename" private/bananacms.tgz
echo "Packed: private/bananacms.tgz"
