# Public origin the consumer zone is served on. Used for CORS, metadata
# (metadataBase), and asset URL formation. No trailing slash.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Extra hostnames allowed in dev (comma-separated). Usually empty.
ALLOWED_HOSTS=

# Directory for data storage — relative to this .env file (demo/), or absolute.
# The SQLite database is stored inside as database.db.
DATA_PATH=../private

# Directory for on-disk asset storage (originals + optimized variants).
ASSETS_DIRECTORY=/tmp/bananacms-assets

# Optional — override the port used by `cms dev` / `cms start`.
# The front server (filesystem fast path for /d/* image variants, proxy for
# everything else) binds SERVER_PORT — point your reverse proxy here. The CMS
# zone binds SERVER_PORT + 1 and the consumer zone SERVER_PORT + 2, both
# internal.
# SERVER_PORT=3000
# CMS_INTERNAL_URL=http://localhost:3001

# Optional — logging.
# LOG_FORMAT=dev        # "dev" | "json" (defaults to dev in development, json in production)
# LOG_LEVEL=info        # "debug" | "info" | "warn" | "error"
# NO_COLOR=1            # disable ANSI colors in dev formatter

# Optional — automatic database snapshots into DATA_PATH/snapshots.
# SNAPSHOTS_COUNT=5     # max snapshots kept; 0 or unset disables the feature
# SNAPSHOTS_DELAY=600   # seconds between the first DB write and the snapshot capturing it
