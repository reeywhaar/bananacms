#!/bin/bash
set -euo pipefail

DATA_PATH="${DATA_PATH:-private}"
DB_PATH="$DATA_PATH/database.db"

if [ ! -f "$DB_PATH" ]; then
  echo "Database not found: $DB_PATH" >&2
  exit 1
fi

mkdir -p seed
seed_file="seed/database.sql"

tmp_db=$(mktemp --suffix=.db)
trap 'rm -f "$tmp_db"' EXIT

sqlite3 "$DB_PATH" ".backup '$tmp_db'"
sqlite3 "$tmp_db" "DELETE FROM user;"
sqlite3 "$tmp_db" ".dump" > "$seed_file"

echo "Seed created: $seed_file"
